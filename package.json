{
    "name": "tasknest-monorepo",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "start": "concurrently \"npm start --workspace=server\" \"npm start --workspace=client\"",
        "dev": "concurrently \"npm run dev --workspace=server\" \"npm start --workspace=client\"",
        "install-all": "npm install && npm install --workspace=client && npm install --workspace=server"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}